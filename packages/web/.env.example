# ─────────────────────────────────────────────────────────────────────────────
# BrandFactory — `@brandfactory/web` environment.
#
# These vars are read at build time by Vite. Anything prefixed with `VITE_`
# is inlined into the client bundle — do NOT put secrets here. The only
# public-safe Supabase value is the anon key (which is exactly what the
# browser client is designed for).
#
# Defaults assume the dev proxy in `vite.config.ts` — `/api` → :3001 and
# `/rt` → :3001. For prod builds served cross-origin, set absolute URLs
# (`https://api.example.com`, `wss://api.example.com/rt`).
# ─────────────────────────────────────────────────────────────────────────────

# ── API transport ────────────────────────────────────────────────────────────
# Base URL for the Hono server. Relative paths go through the Vite dev proxy
# in development; absolute `https://...` URLs work for cross-origin prod.
VITE_API_BASE_URL=/api

# WebSocket URL for the realtime bus (`/rt`). Accepts either relative
# (`/rt` → auto-upgraded to ws/wss) or absolute (`wss://api.example.com/rt`).
VITE_RT_URL=/rt

# ── Auth provider ────────────────────────────────────────────────────────────
# `local` — dev-only token prompt. Paste any JWT the server's local auth
#           adapter will verify (see server .env.example for AUTH_PROVIDER).
# `supabase` — magic-link sign-in via supabase-js. Requires the two Supabase
#              values below.
VITE_AUTH_PROVIDER=local

# ── Supabase (required when VITE_AUTH_PROVIDER=supabase) ─────────────────────
# Project URL from the Supabase dashboard (Settings → API).
VITE_SUPABASE_URL=
# Public anon key — safe to expose in the browser (Supabase's RLS is the
# trust boundary). Never put the service-role key here.
VITE_SUPABASE_ANON_KEY=
