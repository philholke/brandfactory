# ─────────────────────────────────────────────────────────────────────────────
# BrandFactory environment.
#
# `*_PROVIDER` vars pick which adapter the server wires up at boot. The server
# validates the full env via zod (`packages/server/src/env.ts`) — missing
# required fields fail loudly with a readable error.
#
# `drizzle-kit` does not auto-load `.env` — export the variable in your shell,
# or prefix the command (e.g. `DATABASE_URL=... pnpm -F @brandfactory/db
# db:migrate`).
# ─────────────────────────────────────────────────────────────────────────────

# Postgres connection string. Matches the `postgres` service in
# `docker/compose.yaml`. Read by `@brandfactory/db` at runtime and by
# drizzle-kit at migration time.
DATABASE_URL=postgres://brandfactory:brandfactory@localhost:5432/brandfactory

# ── Adapter selection ────────────────────────────────────────────────────────
AUTH_PROVIDER=local              # local | supabase
STORAGE_PROVIDER=local-disk      # local-disk | supabase
REALTIME_PROVIDER=native-ws      # native-ws  (only impl shipped in Phase 3)
LLM_PROVIDER=openrouter          # openrouter | anthropic | openai | ollama
LLM_MODEL=anthropic/claude-sonnet-4.6

# ── Local-disk blob store (required when STORAGE_PROVIDER=local-disk) ────────
# Filesystem root holding blobs.
BLOB_LOCAL_DISK_ROOT=./.data/blobs
# HMAC secret used to sign read/write URLs. Long random string. Server-only.
BLOB_SIGNING_SECRET=change-me-in-prod
# Public base URL the server serves blobs from. Phase 4 mounts the verifying
# `/blobs/:key?sig=...` route here.
BLOB_PUBLIC_BASE_URL=http://localhost:3001/blobs
# Note: the signed-URL `/blobs` routes are only mounted when
# STORAGE_PROVIDER=local-disk. Supabase serves signed URLs directly.

# ── Supabase (auth + storage share these) ────────────────────────────────────
# Required when AUTH_PROVIDER=supabase or STORAGE_PROVIDER=supabase.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
# JWKS endpoint for the Supabase project. Required for AUTH_PROVIDER=supabase.
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=
# Bucket name for STORAGE_PROVIDER=supabase.
SUPABASE_STORAGE_BUCKET=brandfactory

# ── LLM provider keys (required for the active LLM_PROVIDER) ─────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
# OLLAMA_BASE_URL defaults to http://127.0.0.1:11434 — override only if remote.
OLLAMA_BASE_URL=

# ── HTTP server (Phase 4) ────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info                    # debug | info | warn | error
