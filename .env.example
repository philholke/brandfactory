# Postgres connection string. Matches the `postgres` service in
# `docker/compose.yaml`. Every package that talks to Postgres reads this:
# `@brandfactory/db` at runtime (`src/client.ts`) and drizzle-kit at
# migration time (`packages/db/drizzle.config.ts`).
#
# `drizzle-kit` does not auto-load `.env` files — export the variable in
# your shell, or prefix the command (e.g. `DATABASE_URL=... pnpm -F
# @brandfactory/db db:migrate`).
DATABASE_URL=postgres://brandfactory:brandfactory@localhost:5432/brandfactory
