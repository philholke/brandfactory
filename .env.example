# ─────────────────────────────────────────────────────────────────────────────
# BrandFactory — server environment template.
#
# Copy to `.env` at the repo root and fill in what's needed. Loaded by
# `@brandfactory/server` via `packages/server/src/env.ts`; every key below
# appears in `EnvSchema` there. A drift-guard test in
# `packages/server/src/env.example.test.ts` fails the build the moment the
# schema widens without this file following.
#
# Frontend (`VITE_*`) env vars live in `packages/web/.env.example`; those
# are inlined into the client bundle and must not be secrets.
#
# The shipped defaults boot the path that exercises the most code with the
# fewest third-party accounts: `local` auth + `local-disk` storage +
# `native-ws` realtime + `openrouter` LLM. The only secret a contributor
# needs to fill in is `OPENROUTER_API_KEY`.
#
# `drizzle-kit` does not auto-load `.env` — export `DATABASE_URL` in your
# shell, or prefix the command (e.g. `DATABASE_URL=... pnpm -F
# @brandfactory/db db:migrate`).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Postgres connection string. Matches the `postgres` service in
# `docker/compose.yaml`.
DATABASE_URL=postgres://brandfactory:brandfactory@localhost:5432/brandfactory

# ── Auth ─────────────────────────────────────────────────────────────────────
# `local`    — bearer token is a user UUID; the seed script prints one.
# `supabase` — verifies JWTs against SUPABASE_JWKS_URL (set below).
AUTH_PROVIDER=local

# ── Storage ──────────────────────────────────────────────────────────────────
# `local-disk` — writes blobs under BLOB_LOCAL_DISK_ROOT, server signs URLs.
# `supabase`   — proxies to Supabase Storage.
STORAGE_PROVIDER=local-disk

# ── Realtime ─────────────────────────────────────────────────────────────────
# Only `native-ws` ships today; the enum widens when a second impl lands.
REALTIME_PROVIDER=native-ws

# ── LLM ──────────────────────────────────────────────────────────────────────
# Active provider + model. Workspace-level overrides (Settings UI) shadow
# these defaults per workspace.
LLM_PROVIDER=openrouter
LLM_MODEL=anthropic/claude-sonnet-4.6

# ── Blob local-disk config ───────────────────────────────────────────────────
# Required when STORAGE_PROVIDER=local-disk.
BLOB_LOCAL_DISK_ROOT=./.data/blobs
# HMAC secret for signing read/write URLs. Long random string. Server-only.
BLOB_SIGNING_SECRET=change-me-in-prod
# Public base URL the server serves blobs from. Phase 4 mounts the
# verifying `/blobs/:key?sig=...` route here.
BLOB_PUBLIC_BASE_URL=http://localhost:3001/blobs
# Hard cap on `PUT /blobs/:key` request body. Defaults to 25 MiB when
# unset; applied regardless of STORAGE_PROVIDER. 413 BLOB_TOO_LARGE is
# returned before the body is read.
# BLOB_MAX_BYTES=26214400

# ── Supabase (auth + storage share these) ────────────────────────────────────
# Required when AUTH_PROVIDER=supabase:
#   SUPABASE_JWKS_URL (and usually the JWT issuer/audience pair).
# Required when STORAGE_PROVIDER=supabase:
#   SUPABASE_URL + SUPABASE_SERVICE_KEY + SUPABASE_STORAGE_BUCKET.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOi...
# SUPABASE_SERVICE_KEY=eyJhbGciOi...
# SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_JWT_AUDIENCE=authenticated
# SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
# SUPABASE_STORAGE_BUCKET=brandfactory

# ── LLM provider keys ────────────────────────────────────────────────────────
# Set the key matching LLM_PROVIDER above. OpenRouter is the default so
# new contributors can run end-to-end against any OpenRouter-listed model
# with a single account.
OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL defaults to https://openrouter.ai/api/v1.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OLLAMA_BASE_URL defaults to http://127.0.0.1:11434 — override only if remote.
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# ── HTTP server ──────────────────────────────────────────────────────────────
# PORT=3001
# HOST=0.0.0.0
# LOG_LEVEL=info

# ── CORS (split-origin deploys only) ─────────────────────────────────────────
# Comma-separated allowlist of browser origins that may call the API +
# connect to `/rt`. Unset → no CORS headers (single-origin dev via Vite's
# proxy works without this). Set → gates both HTTP `cors()` and the WS
# upgrade `Origin` header with exact-match.
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com
